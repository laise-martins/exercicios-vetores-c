#include <stdio.h>

int main() {
    int vetor[10];
    int i;

    // Leitura
    for(i = 0; i < 10; i++) {
        printf("Digite um numero: ");
        scanf("%d", &vetor[i]);
    }

    // Exibição
    printf("\nElementos do vetor:\n");

    for(i = 0; i < 10; i++) {
        printf("%d ", vetor[i]);
    }

    return 0;
}
