#include <stdio.h>

int main() {
    int vetor[10];
    int i;
    int positivos = 0, negativos = 0, zeros = 0;

    for(i = 0; i < 10; i++) {
        printf("Digite um numero: ");
        scanf("%d", &vetor[i]);

        if(vetor[i] > 0) {
            positivos++;
        }
        else if(vetor[i] < 0) {
            negativos++;
        }
        else {
            zeros++;
        }
    }

    printf("\nPositivos: %d\n", positivos);
    printf("Negativos: %d\n", negativos);
    printf("Zeros: %d\n", zeros);

    return 0;
}
