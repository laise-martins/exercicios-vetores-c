#include <stdio.h>

int main() {
    int vetor[10];
    int i, maior;

    for(i = 0; i < 10; i++) {
        printf("Digite um numero: ");
        scanf("%d", &vetor[i]);
    }

    maior = vetor[0];

    for(i = 1; i < 10; i++) {
        if(vetor[i] > maior) {
            maior = vetor[i];
        }
    }

    printf("\nMaior valor = %d\n", maior);

    return 0;
}
