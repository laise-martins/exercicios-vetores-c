#include <stdio.h>

int main() {
    int vetor[10];
    int i, x;
    int encontrado = 0;

    for(i = 0; i < 10; i++) {
        printf("Digite um numero: ");
        scanf("%d", &vetor[i]);
    }

    printf("Digite o valor de X: ");
    scanf("%d", &x);


    for(i = 0; i < 10; i++) {
        if(vetor[i] == x) {
            encontrado = 1;
        }
    }

    if(encontrado) {
        printf("O valor esta no vetor.\n");
    }
    else {
        printf("O valor nao esta no vetor.\n");
    }

    return 0;
}
